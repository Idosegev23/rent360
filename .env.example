# GreenAPI (legacy — being deprecated; remove once Meta Cloud API is live)
GREENAPI_INSTANCE_ID=
GREENAPI_API_TOKEN_INSTANCE=

# Meta WhatsApp Business Cloud API (Graph API v23.0)
# Fill these in once the number is verified in Meta Business Manager → WhatsApp Manager.
# PHONE_NUMBER_ID and BUSINESS_ACCOUNT_ID come from WhatsApp Manager.
# ACCESS_TOKEN should be a long-lived system-user token (not the 24h test token).
# APP_SECRET is the Facebook app secret used to verify X-Hub-Signature-256 on the webhook.
# WEBHOOK_VERIFY_TOKEN is a random string you generate and paste into Meta's webhook config.
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Supabase client (browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server (service role)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# OpenAI (AI conversation agent + property descriptions)
OPENAI_API_KEY=

# App
APP_BASE_URL=

# Telegram (admin alerts — bot token + numeric chat_id of the admin who should receive handoff/urgent notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Renter automation (Phase 1 auto-dispatch + Phase 2 reply-bot)
# Auto-dispatch tuning (optional; sensible defaults in code): min match score (90), per-renter/day cap (3).
RENTER_ALERT_MIN_SCORE=
RENTER_PER_DAY_CAP=
# Phase 2 reply-bot master switch. When 'true', a renter's reply to a match alert is answered by the
# AI reply-bot (share-safe Q&A, never the street). Leave unset/false to keep replies parked for a human.
RENTER_REPLY_BOT_ENABLED=
# Phase 3 smart viewing scheduler master switch. When 'true', "interested" triggers the 3-way flow
# (read agent free/busy → propose 3 slots → renter picks → landlord confirms → book + notify).
# Requires each agent to reconnect Google (calendar.readonly) + the 2 viewing_* templates approved.
VIEWING_SCHEDULER_ENABLED=

# Google integration (direct OAuth — Calendar events + Gmail send, per-user)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Defaults to ${APP_BASE_URL}/api/google/callback when unset:
GOOGLE_REDIRECT_URI=
# 32-byte base64 key for encrypting stored refresh tokens (openssl rand -base64 32):
GOOGLE_TOKEN_ENC_KEY=
